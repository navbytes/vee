{
  "id": "com.vee.github",
  "name": "GitHub Pull Requests",
  "version": "0.1.0",
  "entrypoint": "../../dist/com.vee.github.js",
  "commands": [
    {
      "name": "view",
      "title": "GitHub Pull Requests",
      "subtitle": "Your open PRs across GitHub",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "token",
      "type": "password",
      "title": "Personal Access Token",
      "description": "A GitHub personal access token with the `repo` scope so Vee can read your open pull requests.",
      "required": true,
      "placeholder": "ghp_…"
    }
  ],
  "capabilities": {
    "network": ["api.github.com", "github.com"],
    "open": ["https"],
    "filesystem": [],
    "clipboard": false,
    "calendar": false,
    "keychainNamespaces": [],
    "hotkeyActions": []
  }
}
