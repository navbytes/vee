{
  "id": "com.vee.jira",
  "name": "Jira Issues",
  "version": "0.1.0",
  "entrypoint": "../../dist/com.vee.jira.js",
  "commands": [
    {
      "name": "view",
      "title": "Jira Issues",
      "subtitle": "Issues assigned to you",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "site",
      "type": "textfield",
      "title": "Jira Site",
      "description": "Your Atlassian site, e.g. yourteam.atlassian.net",
      "required": true,
      "placeholder": "yourteam.atlassian.net"
    },
    {
      "name": "email",
      "type": "textfield",
      "title": "Account Email",
      "required": true
    },
    {
      "name": "token",
      "type": "password",
      "title": "API Token",
      "description": "An Atlassian API token.",
      "required": true
    }
  ],
  "capabilities": {
    "network": [".atlassian.net"],
    "open": ["https"],
    "filesystem": [],
    "clipboard": false,
    "calendar": false,
    "keychainNamespaces": [],
    "hotkeyActions": []
  }
}
