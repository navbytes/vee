{
  "name": "@vee/plugins",
  "version": "0.1.0",
  "private": true,
  "description": "Vee plugin SDK + esbuild bundling pipeline (TypeScript, no React).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/*",
    "samples/*"
  ],
  "scripts": {
    "build": "node bundle.mjs",
    "build:once": "node bundle.mjs --once",
    "test": "node --test"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3"
  }
}
